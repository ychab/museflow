##############################################################
# .env — personal overrides and secrets
#
# Copy this file to .env and fill in your values.
# Non-secret defaults live in .envrc (loaded automatically
# by direnv). Only put secrets and personal overrides here.
##############################################################


#########################################
# Secrets (required)
#########################################

# Spotify API credentials (from developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=<your-spotify-client-id>
SPOTIFY_CLIENT_SECRET=<your-spotify-client-secret>

# Gemini API key (from aistudio.google.com)
GEMINI_API_KEY=<your-gemini-api-key>

# App secret key — min 32 characters, generate with: openssl rand -hex 32
MUSEFLOW_SECRET_KEY=<min-32-character-secret-key>


#########################################
# Personal overrides (optional)
#########################################

# Override the database port if you use a non-standard one:
# DATABASE_PORT=5433

# Override database password if different from the Docker default:
# DATABASE_PASSWORD=mypassword

# Gemini model overrides (defaults are set in the app):
# GEMINI_ADVISOR_MODEL=gemini-2.5-flash
# GEMINI_PROFILER_SEGMENT_MODEL=gemini-2.5-flash-lite
# GEMINI_PROFILER_MERGE_MODEL=gemini-2.5-flash
# GEMINI_PROFILER_REFLECT_MODEL=gemini-2.5-pro-preview
