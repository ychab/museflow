{
  "request": {
    "method": "GET",
    "urlPath": "/search",
    "queryParameters": {
      "offset": { "matches": "[0-9]+" },
      "limit": { "matches": "[0-9]+" },
      "type": { "equalTo": "track" }
    }
  },
  "response": {
    "status": 200,
    "transformers": ["response-template"],
    "bodyFileName": "search_track_page_{{math (math request.query.offset '/' request.query.limit) '+' 1}}.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
